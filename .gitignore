# Python
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/
.venv/
venv/

# Tooling caches
.pytest_cache/
.ruff_cache/
.mypy_cache/

# uv
uv.lock

# DVC 实际数据由 DVC 跟踪；原始大文件不进 git
/data/raw/
/data/interim/
/data/processed/*
# 例外：分类 manifest 是可移植的小文本契约（相对路径+记录 root），随 git 走，
# 换机用 data.data_root 覆盖即可复用（detection labels.json 绑大图，不在此例外）
!/data/processed/birds525
/data/processed/birds525/*
!/data/processed/birds525/manifest.json
!/data/processed/birds525/ebird_map.csv
!/data/processed/birds525/ebird_aliases.csv
# 注：ebird_taxonomy.csv(1.47M, 可 curl 重拉)仍 ignore；ebird_map.csv(小, 可移植) 随 git
*.nb

# 训练/实验产物
outputs/
lightning_logs/
*.onnx
*.ckpt
.hydra/

# Env / IDE / OS
.env
.idea/
.vscode/
.DS_Store
third_party/
weights/
results/**/*.pth

# 本地审查产物（大，含内嵌图，不入库）
检测数据集_*.html

# round2：模型权重(541MB, DVC 领域不进 git)；exports 为冗余中间件(ncnn 正本在 mobile_handoff/)
results/detect/round2/checkpoints/
results/detect/round2/exports/
results/detect/mobile_handoff_nanodet/round3/p*/ckpt/
results/detect/mobile_handoff_ppyoloe/round3/ckpt/

# handoff 交接包：onnx 随包进 git（自足包，对齐 round2；覆盖上面 *.onnx 全局忽略）。tflite 无全局规则、本就入库；ckpt 续训权重上面已忽略。
!results/detect/mobile_handoff_nanodet/**/*.onnx
!results/detect/mobile_handoff_ppyoloe/**/*.onnx
